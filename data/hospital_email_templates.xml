<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_appointment_confirm" model="mail.template">
            <field name="name">Appointment: Confirmation</field>
            <field name="model_id" ref="hospital_management.model_hospital_appointment"/>
            <field name="subject">Appointment Confirmation</field>
            <field name="email_from">{{ user.email_formatted or 'info@hospital.com'}}</field>
            <field name="email_to">{{ object.patient_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear <t t-out="object.patient_id.name or 'Patient'"/>,<br/><br/>
                        Your appointment has been confirmed.<br/><br/>
                        <strong>Doctor:</strong> <t t-out="object.doctor_id.name"/><br/>
                        <strong>Date:</strong> <t t-out="object.date"/><br/><br/>
                        Thank you,<br/>
                        <t t-out="user.company_id.name"/>
                    </p>
                </div>
            </field>
        </record>

        <record id="email_template_appointment_to_doctor" model="mail.template">
            <field name="name">Appointment Approval Request</field>
            <field name="model_id" ref="hospital_management.model_hospital_appointment"/>
            <field name="subject">Appointment Approval Needed</field>
            <field name="email_from">{{ user.email_formatted or 'info@hospital.com'}}</field>
            <field name="email_to">{{ object.doctor_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear <t t-out="object.doctor_id.name or 'Doctor'"/>,<br/><br/>
                        A new appointment has been created and requires your approval.<br/><br/>
                        <strong>Patient:</strong> <t t-out="object.patient_id.name"/><br/>
                        <strong>Date:</strong> <t t-out="object.date"/><br/><br/>
                        Please log in to approve this appointment.<br/><br/>
                        Thank you,<br/>
                        <t t-out="user.company_id.name"/>
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>