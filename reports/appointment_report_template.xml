<odoo>
    <template id="report_appointments_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="appointment">
                <div class="page">
                    <h2>Appointment Report</h2>
                    <p><strong>Date:</strong> <t t-esc="appointment.date"/></p>
                    <p><strong>Doctor:</strong> <t t-esc="appointment.doctor_id.name"/></p>
                    <p><strong>Patient:</strong> <t t-esc="appointment.patient_id.name"/></p>
                </div>
            </t>
        </t>
    </template>

    <report
        id="action_report_appointments_pdf"
        model="appointment.report.wizard"
        string="Appointments PDF"
        report_type="qweb-pdf"
        name="appointment_report_wizard.report_appointments_pdf"
        file="appointment_report_wizard.report_appointments_pdf"
    />
</odoo>
