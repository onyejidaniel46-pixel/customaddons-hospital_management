<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Doctor Tree view -->
    <record id="view_hospital_doctor_tree" model="ir.ui.view">
        <field name="name">hospital.doctor.tree</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="specialty"/>
                <field name="email"/>
            </tree>
        </field>
    </record>

    <!-- Doctor Form view -->
    <record id="view_hospital_doctor_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="specialty"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Patients">
                            <field name="patient_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Appointments">
                            <field name="appointment_ids">
                                <tree editable="bottom">
                                    <field name="patient_id"/>
                                    <field name="date"/>
                                    <field name="state"/>
                                    <button name="action_confirm" type="object" string="Approve" class="oe_highlight" attrs="{'invisible': [('state','!=','sent')]}"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Doctor Action -->
    <record id="action_hospital_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
