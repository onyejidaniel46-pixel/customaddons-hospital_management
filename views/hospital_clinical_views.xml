        <field name="model">hospital.ambulance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,dispatched,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Request Details">
                            <field name="patient_id"/>
                            <field name="request_date"/>
                            <field name="pickup_location"/>
                            <field name="destination"/>
                        </group>
                        <group string="Vehicle Info">
                            <field name="driver"/>
                            <field name="vehicle_number"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_hospital_ambulance" model="ir.actions.act_window">
        <field name="name">Ambulance</field>
        <field name="res_model">hospital.ambulance</field>
        <field name="view_mode">tree,form</field>
    </record>

