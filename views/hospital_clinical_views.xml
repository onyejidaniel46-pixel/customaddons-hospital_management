<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- MEDICATION -->
    <record id="view_hospital_medication_tree" model="ir.ui.view">
        <field name="name">hospital.medication.tree</field>
        <field name="model">hospital.medication</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="category"/>
                <field name="dosage"/>
                <field name="expiry_date"/>
                <field name="safe_for_pregnant"/>
            </tree>
        </field>
    </record>
    <record id="view_hospital_medication_form" model="ir.ui.view">
        <field name="name">hospital.medication.form</field>
        <field name="model">hospital.medication</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Medicine Name"/></h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="category"/>
                            <field name="therapeutic_effect"/>
                            <field name="active_components"/>
                        </group>
                        <group string="Details">
                            <field name="presentation"/>
                            <field name="dosage"/>
                            <field name="expiry_date"/>
                            <field name="safe_for_pregnant"/>
                        </group>
                    </group>
                    <group>
                        <group string="Composition">
                            <field name="composition"/>
                        </group>
                        <group string="Storage">
                            <field name="storage_conditions"/>
                        </group>
                    </group>
                    <group string="Adverse Reactions">
                        <field name="adverse_reaction" nolabel="1"/>
                    </group>
                    <group string="Extra Information">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_hospital_medication" model="ir.actions.act_window">
        <field name="name">Medications</field>
        <field name="res_model">hospital.medication</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- VACCINATION -->
    <record id="view_hospital_vaccination_tree" model="ir.ui.view">
        <field name="name">hospital.vaccination.tree</field>
        <field name="model">hospital.vaccination</field>
        <field name="arch" type="xml">
            <tree>
                <field name="patient_id"/>
                <field name="vaccine"/>
                <field name="physician_id"/>
                <field name="date"/>
                <field name="next_dose_date"/>
            </tree>
        </field>
    </record>
    <record id="view_hospital_vaccination_form" model="ir.ui.view">
        <field name="name">hospital.vaccination.form</field>
        <field name="model">hospital.vaccination</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="patient_id"/>
                        <field name="vaccine"/>
                        <field name="physician_id"/>
                        <field name="date"/>
                        <field name="next_dose_date"/>
                        <field name="lot_number"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_hospital_vaccination" model="ir.actions.act_window">
        <field name="name">Vaccinations</field>
        <field name="res_model">hospital.vaccination</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- IMAGING -->
    <record id="view_hospital_imaging_tree" model="ir.ui.view">
        <field name="name">hospital.imaging.tree</field>
        <field name="model">hospital.imaging</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="physician_id"/>
                <field name="imaging_type"/>
                <field name="body_part"/>
                <field name="date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_hospital_imaging_form" model="ir.ui.view">
        <field name="name">hospital.imaging.form</field>
        <field name="model">hospital.imaging</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Request Information">
                            <field name="patient_id"/>
                            <field name="physician_id"/>
                            <field name="date"/>
                        </group>
                        <group string="Imaging Details">
                            <field name="imaging_type"/>
                            <field name="body_part"/>
                        </group>
                    </group>
                    <group string="Result / Findings">
                        <field name="result" nolabel="1"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_hospital_imaging" model="ir.actions.act_window">
        <field name="name">Imaging</field>
        <field name="res_model">hospital.imaging</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- SURGERY -->
    <record id="view_hospital_surgery_tree" model="ir.ui.view">
        <field name="name">hospital.surgery.tree</field>
        <field name="model">hospital.surgery</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="surgeon_id"/>
                <field name="date"/>
                <field name="surgery_type"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_hospital_surgery_form" model="ir.ui.view">
        <field name="name">hospital.surgery.form</field>
        <field name="model">hospital.surgery</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"
                        statusbar_visible="scheduled,in_progress,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Surgery Information">
                            <field name="patient_id"/>
                            <field name="surgery_type"/>
                            <field name="date"/>
                        </group>
                        <group string="Medical Team">
                            <field name="surgeon_id"/>
                            <field name="assistant_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Result / Notes">
                        <field name="result" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_hospital_surgery" model="ir.actions.act_window">
        <field name="name">Surgery</field>
        <field name="res_model">hospital.surgery</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- AMBULANCE -->
    <record id="view_hospital_ambulance_tree" model="ir.ui.view">
